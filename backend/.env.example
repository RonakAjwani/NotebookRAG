# ---- App / server ----
ENVIRONMENT=development
DEBUG=True
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# ---- Storage paths ----
RAW_DIR=./data/raw
PROCESSED_DIR=./data/processed
CACHE_DIR=./data/cache

# ---- Qdrant ----
# Local docker-compose default. For Qdrant Cloud set the URL + api key.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=internal_docs

# ---- Embeddings (local, no key needed) ----
DENSE_MODEL=BAAI/bge-small-en-v1.5
DENSE_DIMENSION=384
SPARSE_MODEL=Qdrant/bm25

# ---- LLM inference ----
# Which provider generates answers: cerebras | groq | openai
LLM_PROVIDER=cerebras

# Cerebras (https://cloud.cerebras.ai) - default generator
CEREBRAS_API_KEY=your_cerebras_key_here
CEREBRAS_MODEL=gpt-oss-120b

# Groq (https://console.groq.com) - default judge/reranker
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (optional alternative)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OpenRouter (https://openrouter.ai/keys) - optional second judge pool.
# NOTE: free ":free" models are capped at ~50 requests/day unless you have
# bought $10+ of credits once (then ~1000/day).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Fallback judge provider for any role left unset below.
JUDGE_PROVIDER=groq

# --- Per-role LLM routing ("provider" or "provider/model") ---
# Free-tier quotas are per provider AND per model. Cerebras gives each of its
# three models (gpt-oss-120b, zai-glm-4.7, gemma-4-31b) its own ~1M tokens/day
# pool, so spreading roles across models multiplies the daily budget and lets a
# full eval run finish on the free tier without hitting Groq's 100K/day cap.
# Only gpt-oss-120b and gemma-4-31b reliably emit structured JSON; zai-glm-4.7
# fails ~90% of listwise-rerank calls (measured). Rerank orders retrieved
# passages (not generated text) so it can share the generator model; the three
# roles that judge generated text run on gemma (different family = cross-model).
RERANK_LLM=cerebras/gpt-oss-120b
# Verification runs on gemma-4-31b: independent of the generator and reliable in
# free tier. It's a slightly conservative judge, so citation accuracy is a lower
# bound. (groq/llama-3.3-70b is more accurate but its 100K/day cap aborts full runs.)
VERIFY_LLM=cerebras/gemma-4-31b
COMPLETENESS_LLM=cerebras/gemma-4-31b
EVAL_JUDGE_LLM=cerebras/gemma-4-31b
# Stronger-independence alternative for the eval judge (needs the key + quota):
#   EVAL_JUDGE_LLM=groq/llama-3.3-70b-versatile        (100K tok/day cap)
#   EVAL_JUDGE_LLM=openrouter/meta-llama/llama-3.3-70b-instruct   (needs $10 credit for 1000/day)

# Proactive pacing (requests/minute per provider) - prevents 429 backoff storms
CEREBRAS_RPM=5
GROQ_RPM=25
OPENROUTER_RPM=15

# ---- LLM client behaviour ----
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_MAX_RETRIES=6
LLM_CACHE_ENABLED=True

# ---- Chunking: fixed | recursive | semantic ----
CHUNK_STRATEGY=recursive
CHUNK_SIZE=800
CHUNK_OVERLAP=150
SEMANTIC_THRESHOLD=0.75

# ---- Retrieval / fusion ----
DENSE_TOP_K=10
SPARSE_TOP_K=10
RRF_DENSE_WEIGHT=0.7
RRF_SPARSE_WEIGHT=0.3
RERANK_CANDIDATES=20
RERANK_TOP_K=5
RETRIEVAL_CONFIDENCE_THRESHOLD=0.35
